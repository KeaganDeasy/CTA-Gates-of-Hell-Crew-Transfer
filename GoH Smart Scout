# CORE LOGIC FUNCTIONS
# ==========================================
def get_block_fast(text, start_index):
    """Lightning-fast brace matcher that prevents MemoryErrors."""
    brace_count = 0
    in_block = False
    regex = re.compile(r'[{}]')
    for match in regex.finditer(text, start_index):
        char = match.group(0)
        if char == '{':
            brace_count += 1
            in_block = True
        elif char == '}':
            brace_count -= 1
        if in_block and brace_count == 0:
            return text[start_index : match.end()]
    return ""

def surgical_batch_swap(full_text, swap_list):
    """Locates the CampaignSquads block and swaps multiple IDs ONLY within that section."""
    squads_match = re.search(r'\{\s*CampaignSquads\b', full_text, re.IGNORECASE)
    if not squads_match:
        print(f"{Colors.FAIL}Error: Could not find CampaignSquads list.{Colors.ENDC}")
        return full_text

    start_idx = squads_match.start()
    squads_block_full = get_block_fast(full_text, start_idx)
    if not squads_block_full: return full_text

    new_block = squads_block_full
    for rookie_id, veteran_id in swap_list:
        temp_id = f"0xTEMP_SWAP_{rookie_id[2:]}"
        new_block = re.sub(r'(?i)\b' + re.escape(rookie_id) + r'\b', temp_id, new_block)
        new_block = re.sub(r'(?i)\b' + re.escape(veteran_id) + r'\b', rookie_id, new_block)
        new_block = re.sub(r'(?i)\b' + re.escape(temp_id) + r'\b', veteran_id, new_block)
        print(f" • {Colors.GREEN}Surgical Swap:{Colors.ENDC} {rookie_id} <-> {veteran_id}")
    
    return full_text[:start_idx] + new_block + full_text[start_idx + len(squads_block_full):]

def clean_status_mods(status_text):
    """Finds the {mods ...} block and empties it."""
    pattern = re.compile(r'(\{mods\s*).*?(\s*\})', re.DOTALL | re.IGNORECASE)
    return pattern.sub(r'\1\2', status_text)

def parse_save_data(scn_text):
    """Indexes all entities and their veterancy level."""
    entity_map, squads = {}, []
    regex_entity = r'\{\s*(?:Entity|Human|Vehicle)\s+["\']?([^"\'\{\}\s]+)["\']?\s+(0x[0-9a-fA-F]+)'
    for match in re.finditer(regex_entity, scn_text, re.IGNORECASE):
        breed, hex_id = match.group(1).strip(), match.group(2)
        hex_lower = hex_id.lower() 
        if hex_lower in entity_map: continue
        block = get_block_fast(scn_text, match.start())
        if not block: continue
        exp_match = re.search(r'\{(?:Veterancy|Experience|exp|level)\s+["\']?([\d\.]+)["\']?\}', block, re.IGNORECASE)
        entity_map[hex_lower] = {'original_id': hex_id, 'breed': breed, 'exp': float(exp_match.group(1)) if exp_match else 0.0}

    squads_match = re.search(r'\{\s*CampaignSquads\b', scn_text, re.IGNORECASE)
    if not squads_match: return entity_map, squads
    squads_block = get_block_fast(scn_text, squads_match.start())

    squad_counter = 1
    for inner_block in re.finditer(r'\{([^{}]+)\}', squads_block):
        content = inner_block.group(1)
        squad_ids = re.findall(r'(0x[0-9a-fA-F]+)', content)
        if squad_ids:
            all_strings = re.findall(r'["\'](.*?)["\']', content)
            squad_name, actual_members, max_squad_exp = all_strings[0] if all_strings else "Unknown_Squad", [], 0.0
            for cid in squad_ids:
                if cid.lower() in entity_map:
                    actual_members.append(cid) 
                    max_squad_exp = max(max_squad_exp, entity_map[cid.lower()]['exp'])
            if actual_members:
                squads.append({'display_id': f"SQ-{squad_counter:03d}", 'name': squad_name, 'max_exp': max_squad_exp, 'member_ids': actual_members})
                squad_counter += 1
    return entity_map, squads

# ==========================================
# MAIN WORKFLOW
# ==========================================
def main():
    print_header("GoH Crew Role-Safe Transfer Tool")
    print(f"Smart Scout Edition (Batch Mode - Split Context)\n")
    
    # Load configuration
    config = load_config()
    
    # Get save path with interactive selection
    sav_path = get_save_path_interactive(config)
    
    # Validate save file
    print_header("Step 1: Save File Validation")
    valid, errors = validate_save_file(sav_path)
    if not valid:
        display_validation_errors(errors)
        sys.exit(1)
    display_validation_success()
    
    # Update config with new path
    config['default_save_path'] = sav_path
    update_recent_saves(config, sav_path)
    success, error = save_config(config)
    if not success:
        log_error(f"Could not save configuration: {error}")
    
    # Extract and decode campaign.scn
    print_header("Step 2: Unpacking & Indexing")
    success, scn_text, scn_encoding, error = extract_scn_from_zip(sav_path)
    if not success:
        log_error(f"Failed to extract campaign.scn: {error}")
        sys.exit(1)
    
    # Validate campaign structure
    valid, error = validate_campaign_structure(scn_text)
    if not valid:
        log_error(f"Invalid campaign structure: {error}")
        sys.exit(1)
    
    # Parse data
    entity_map, squads = parse_save_data(scn_text)
    if not squads:
        log_error("No squads found in save file")
        sys.exit(1)
    
    cid_to_squad_name = {cid.lower(): sq['name'] for sq in squads for cid in sq['member_ids']}
    
    # Get max candidates from config
    max_candidates = config.get('max_candidates', 100)

    print_header("Step 3: Squad Selection")
    squads.sort(key=lambda x: x['max_exp'], reverse=True)
    display_squad_list(squads)
    
    squad_idx = get_valid_integer(
        f"\n{Colors.BOLD}Select target squad: {Colors.ENDC}",
        min_val=1,
        max_val=len(squads)
    )
    target_squad = squads[squad_idx - 1]

    print_header(f"Step 4: Managing {target_squad['name']}")
    current_crew = []
    for i, cid in enumerate(target_squad['member_ids']):
        h = entity_map.get(cid.lower())
        if h:
            current_crew.append((cid, h['exp'], h['breed']))
    
    display_crew_members(current_crew)
    
    rookie_indices = get_valid_indices(
        f"\n{Colors.BOLD}Select crew to replace (e.g. 1, 2, 3): {Colors.ENDC}",
        max_index=len(current_crew)
    )
    selected_rookies = [current_crew[idx] for idx in rookie_indices]

    print_header("Step 5: Scout Report")
    candidates = []
    if selected_rookies:
        role_key = selected_rookies[0][2].split("_")[-1].split("(")[0]
        for hid_lower, h in entity_map.items():
            if hid_lower not in [c.lower() for c in target_squad['member_ids']] and ('(' in h['breed'] or hid_lower in cid_to_squad_name):
                candidates.append({'id': h['original_id'], 'breed': h['breed'], 'exp': h['exp'], 'role_match': role_key in h['breed'], 'squad': cid_to_squad_name.get(hid_lower, "Reserve")})
    
    candidates.sort(key=lambda x: (-x['exp'], not x['role_match']))
    top_cands = candidates[:max_candidates]
    display_candidates(top_cands)
    
    vet_indices = get_valid_indices(
        f"\n{Colors.BOLD}Select {len(selected_rookies)} veterans: {Colors.ENDC}",
        max_index=len(top_cands),
        required_count=len(selected_rookies)
    )
    selected_vets = [top_cands[idx] for idx in vet_indices]

    swap_list = print_manifest(selected_rookies, selected_vets)
    if not get_yes_no(f"\n{Colors.BOLD}Execute? (y/n): {Colors.ENDC}", default='n'):
        log_success("Operation cancelled by user")
        sys.exit(0)

    print_header("Step 6: Finalizing")
    
    # Create temp directory for processing
    temp_dir = tempfile.mkdtemp(prefix="goh_")
    
    try:
        # Extract entire save file
        with zipfile.ZipFile(sav_path, 'r') as z:
            z.extractall(temp_dir)
        
        # Find campaign.scn file
        scn_filename = None
        for root, dirs, files in os.walk(temp_dir):
            for file in files:
                if any(x in file.lower() for x in ['campaign.scn', 'campaign.scm']):
                    scn_filename = os.path.join(root, file)
                    break
            if scn_filename:
                break
        
        if not scn_filename:
            log_error("Could not find campaign.scn in extracted files")
            shutil.rmtree(temp_dir, ignore_errors=True)
            sys.exit(1)
        
        # Apply surgical swap
        new_scn_text = surgical_batch_swap(scn_text, swap_list)
        with open(scn_filename, 'wb') as f:
            f.write(new_scn_text.encode(scn_encoding))
            f.flush()
            os.fsync(f.fileno())
        
        # Clean status.chs if present
        status_file = None
        for root, dirs, files in os.walk(temp_dir):
            for file in files:
                if 'status' in file.lower():
                    status_file = os.path.join(root, file)
                    break
            if status_file:
                break
        
        if status_file:
            with open(status_file, 'rb') as f:
                raw = f.read()
            s_enc = 'utf-16-le' if raw.startswith(b'\xff\xfe') else 'utf-8'
            with open(status_file, 'wb') as f:
                f.write(clean_status_mods(raw.decode(s_enc, errors='ignore')).encode(s_enc))
        
        # Create new save file
        new_sav_path = f"{os.path.splitext(sav_path)[0]}_MOD_{datetime.now().strftime('%H%M')}.sav"
        with zipfile.ZipFile(new_sav_path, 'w', zipfile.ZIP_DEFLATED) as z:
            for root, dirs, files in os.walk(temp_dir):
                for file in files:
                    fp = os.path.join(root, file)
                    z.write(fp, os.path.relpath(fp, temp_dir))
        
        shutil.rmtree(temp_dir, ignore_errors=True)
        print(f"\n{Colors.GREEN}{Colors.BOLD}SUCCESS!{Colors.ENDC}\nCreated: {os.path.basename(new_sav_path)}")
        
    except Exception as e:
        log_error(f"Error during finalization: {e}")
        shutil.rmtree(temp_dir, ignore_errors=True)
        sys.exit(1)

if __name__ == "__main__":
    try: main()
    except KeyboardInterrupt: sys.exit(0)